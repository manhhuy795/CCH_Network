# Copy to .env and fill values before connecting to real devices.
NET_USERNAME=netops
NET_PASSWORD=change-me
NET_SECRET=

# Safety gate. Keep false unless you intentionally connect to real/lab devices.
CONFIRM_DEPLOY=false

# Optional knobs
NET_TIMEOUT=30
BACKUP_RETENTION_DAYS=30

# Optional SDN controller integration. Leave empty for offline render only.
SDN_CONTROLLER_URL=
SDN_USERNAME=
SDN_PASSWORD=

# Dashboard IT-only access
CCH_DASHBOARD_TOKEN=it-support-demo
CCH_DASHBOARD_HOST=0.0.0.0
CCH_DASHBOARD_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
