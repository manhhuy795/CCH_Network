# Copy to .env and fill values before connecting to real devices.
NET_USERNAME=netops
NET_PASSWORD=change-me
NET_SECRET=

# Safety gate. Real deploy/backup/verify still requires reachable inventory.
CONFIRM_DEPLOY=true

# Optional knobs
NET_TIMEOUT=30
BACKUP_RETENTION_DAYS=30

# Optional SDN controller integration. Leave empty for offline render only.
SDN_CONTROLLER_URL=
SDN_USERNAME=
SDN_PASSWORD=
