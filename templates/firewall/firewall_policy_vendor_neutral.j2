# Generated vendor-neutral firewall policy for {{ device.name }}
# Convert to the target firewall vendor syntax and validate before production.

firewall: {{ firewall_site.firewall_name }}
site: {{ device.site }}
interfaces:
  inside: {{ firewall_site.inside_interface }}
  outside: {{ firewall_site.outside_interface }}
  runtime_inside: {{ firewall_site.runtime_interfaces.inside }}
  runtime_outside: {{ firewall_site.runtime_interfaces.outside }}

nat:
  enabled: {{ config.firewall_policy.runtime_defaults.nat.enabled }}
  mode: {{ config.firewall_policy.runtime_defaults.nat.mode }}
  reason: "{{ config.firewall_policy.runtime_defaults.nat.reason }}"

objects:
{% for name, object in config.firewall_policy.shared_objects.applications.items() %}
  {{ name }}:
    type: {{ object.type }}
{% if object.fqdn is defined %}
    fqdn: {{ object.fqdn }}
{% endif %}
{% if object.ip is defined %}
    ip: {{ object.ip }}
{% endif %}
{% if object.ports is defined %}
    ports: {{ object.ports }}
{% endif %}
{% if object.categories is defined %}
    categories: {{ object.categories }}
{% endif %}
    notes: "{{ object.notes | default('') }}"
{% endfor %}

policies:
{% for policy in firewall_site.policies %}
  - name: {{ policy.name }}
    action: {{ policy.action }}
    source_vlans: {{ policy.sources }}
    destination: {{ policy.destinations }}
    applications: {{ policy.applications }}
    enable_flag: {{ policy.enable_flag }}
    counter: {{ config.firewall_policy.runtime_defaults.counter_enabled }}
    log: {{ policy.log }}
{% endfor %}
